generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Models ──────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  hashedPassword String?
  role           Role      @default(EDITOR)
  image          String?
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  assignedLeads        Lead[]              @relation("AssignedLeads")
  assignedAppointments AppointmentRequest[] @relation("AssignedAppointments")
  processedPrivacyRequests DataPrivacyRequest[] @relation("ProcessedPrivacyRequests")
  uploadedMedia        MediaAsset[]
  notificationRecipients NotificationRecipient[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ──────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  IN_PROGRESS
  CONVERTED
  CLOSED
}

model Lead {
  id            String     @id @default(cuid())
  fullName      String
  email         String
  phone         String
  country       String
  destination   String
  situation     String?
  serviceNeeded String?
  message       String?    @db.Text
  consent       Boolean    @default(false)
  status        LeadStatus @default(NEW)
  source        String?
  notes         String?    @db.Text
  tags          String[]
  assignedToId  String?
  assignedTo    User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([assignedToId])
}

model ContactRequest {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  status    ContactRequestStatus @default(NEW)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([status])
  @@index([createdAt])
}

enum ContactRequestStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum AppointmentStatus {
  PENDING
  APPROVED
  CANCELLED
  COMPLETED
}

enum AdminNotificationType {
  LEAD_CREATED
  CONTACT_CREATED
  APPOINTMENT_CREATED
  APPOINTMENT_APPROVED
  APPOINTMENT_CANCELLED
  APPOINTMENT_COMPLETED
  LEAD_ASSIGNED
  USER_CREATED
  PRIVACY_REQUEST_CREATED
}

enum DataPrivacyRequestType {
  ACCESS
  RECTIFICATION
  ERASURE
  PORTABILITY
  OBJECTION
  WITHDRAW_CONSENT
}

enum DataPrivacyRequestStatus {
  RECEIVED
  IDENTITY_PENDING
  IN_REVIEW
  FULFILLED
  REJECTED
}

model AppointmentRequest {
  id              String            @id @default(cuid())
  fullName        String
  email           String
  phone           String
  preferredDate   DateTime?
  preferredTime   String?
  serviceType     String?
  destinationType String?
  message         String?           @db.Text
  status          AppointmentStatus @default(PENDING)
  notes           String?           @db.Text
  assignedToId    String?
  assignedTo      User?             @relation("AssignedAppointments", fields: [assignedToId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([createdAt])
}

model DataPrivacyRequest {
  id              String                   @id @default(cuid())
  fullName        String
  email           String
  phone           String?
  requestType     DataPrivacyRequestType
  message         String?                  @db.Text
  status          DataPrivacyRequestStatus @default(RECEIVED)
  resolutionNotes String?                  @db.Text
  processedAt     DateTime?
  processedById   String?
  processedBy     User?                    @relation("ProcessedPrivacyRequests", fields: [processedById], references: [id])
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([email])
  @@index([status, createdAt])
  @@index([processedById])
  @@index([createdAt])
}

model Destination {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  heroTitle       String
  heroDescription String?  @db.Text
  heroImage       String?
  opportunities   Json?
  visaCategories  Json?
  whyChoose       Json?
  ctaText         String?
  published       Boolean  @default(false)
  order           Int      @default(0)
  seoTitle        String?
  seoDescription  String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  faqs         FAQ[]
  testimonials Testimonial[]

  @@index([published, order])
}

model Service {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  icon            String?
  description     String?  @db.Text
  whoIsItFor      String?  @db.Text
  requiredSupport String?  @db.Text
  benefits        Json?
  ctaText         String?
  published       Boolean  @default(false)
  order           Int      @default(0)
  seoTitle        String?
  seoDescription  String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([published, order])
}

enum FAQCategory {
  GENERAL
  CANADA
  USA
  EUROPE
  DOCUMENTATION
  PROCESS
}

model FAQ {
  id            String       @id @default(cuid())
  question      String
  answer        String       @db.Text
  category      FAQCategory  @default(GENERAL)
  destinationId String?
  destination   Destination? @relation(fields: [destinationId], references: [id])
  published     Boolean      @default(false)
  order         Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([published, category])
  @@index([destinationId])
}

model Testimonial {
  id             String       @id @default(cuid())
  clientName     String
  clientImage    String?
  destination    String?
  destinationId  String?
  destinationRef Destination? @relation(fields: [destinationId], references: [id])
  content        String       @db.Text
  rating         Int          @default(5)
  featured       Boolean      @default(false)
  published      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([published, featured])
}

model SuccessStory {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  clientName     String
  destination    String
  summary        String?  @db.Text
  content        String?  @db.Text
  images         Json?
  published      Boolean  @default(false)
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published])
}

model PageContent {
  id         String   @id @default(cuid())
  pageKey    String
  sectionKey String
  title      String?
  subtitle   String?
  content    Json?
  published  Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([pageKey, sectionKey])
  @@index([pageKey])
}

enum SettingType {
  TEXT
  IMAGE
  JSON
  BOOLEAN
}

model SiteSetting {
  id        String      @id @default(cuid())
  key       String      @unique
  value     String      @db.Text
  type      SettingType @default(TEXT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model MediaAsset {
  id           String   @id @default(cuid())
  filename     String
  url          String
  mimeType     String
  size         Int
  alt          String?
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
}

model AdminNotification {
  id         String                @id @default(cuid())
  type       AdminNotificationType
  title      String
  message    String                @db.Text
  entityType String?
  entityId   String?
  actionUrl  String?
  metadata   Json?
  createdAt  DateTime              @default(now())

  recipients NotificationRecipient[]

  @@index([createdAt])
  @@index([type, createdAt])
}

model NotificationRecipient {
  id             String            @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime?
  createdAt      DateTime          @default(now())

  notification AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt, createdAt])
  @@index([notificationId])
}

// ─── AI Chat Models ─────────────────────────────────────────────

enum ChatChannel {
  PUBLIC
  ADMIN
}

model ChatConversation {
  id        String        @id @default(cuid())
  sessionId String
  channel   ChatChannel  @default(PUBLIC)

  userId    String?
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages ChatMessage[]

  @@index([sessionId])
  @@index([userId])
  @@index([channel])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String           // "user", "assistant", "system"
  content        String           @db.Text
  createdAt      DateTime         @default(now())

  @@index([conversationId])
}

// ─── Rate Limiting ───────────────────────────────────────────────

model ChatRateLimit {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}
